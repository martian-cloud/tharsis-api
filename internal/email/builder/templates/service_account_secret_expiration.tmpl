<h6 class="text" style="color:orange;">
    Service Account Client Secret Expiring Soon
</h6>
<hr class="divider" />

<p class="text">
    <strong>Service Account:</strong>
</p>
<p class="text gutter-bottom">
    {{.this.ServiceAccountName}}
</p>

<p class="text">
    <strong>Group:</strong>
</p>
<p class="text gutter-bottom">
    <a href="{{.common.FrontendURL}}/groups/{{.this.GroupPath}}" class="link" target="_blank">
        {{.this.GroupPath}}
    </a>
</p>

<p class="text">
    <strong>Expires:</strong>
</p>
<p class="text gutter-bottom" style="color:orange;">
    <strong>{{.this.ExpiresAt.Format "January 2, 2006"}}</strong>
</p>

<p class="text gutter-bottom">
    Please regenerate the client credentials before they expire to avoid service disruption.
</p>

<a class="primary-button" style="margin-top: 24px;"
    href="{{.common.FrontendURL}}/groups/{{.this.GroupPath}}/-/service_accounts/{{.this.ServiceAccountID}}"
    target="_blank">
    <span class="primary-button-text">
        View Service Account
    </span>
</a>
